{
  "expo": {
    "name": "慢病饮食助手",
    "slug": "health-monitor-app",
    "version": "1.1.0",
    "runtimeVersion": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.healthmonitor.chroniccare",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "拍摄食物照片，AI 分析食物对您慢性病的健康影响",
        "NSPhotoLibraryUsageDescription": "从相册选择食物照片进行健康分析",
        "NSPhotoLibraryAddUsageDescription": "保存食物分析报告到相册",
        "NSUserNotificationsUsageDescription": "发送三餐记录提醒和饮水提醒"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F2F2F7",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.healthmonitor.chroniccare",
      "versionCode": 3,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "从相册选择食物照片进行健康分析",
          "cameraPermission": "拍摄食物照片，AI 分析食物对您慢性病的健康影响"
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "health-monitor-app"
      }
    }
  }
}
